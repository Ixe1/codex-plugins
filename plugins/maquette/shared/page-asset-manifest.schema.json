{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Ixe1/codex-plugins/master/plugins/maquette/shared/page-asset-manifest.schema.json",
  "title": "Maquette Page Asset Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "page",
    "status",
    "assets",
    "review"
  ],
  "properties": {
    "page": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "reviewed",
        "approved"
      ]
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "allOf": [
          {
            "if": {
              "properties": {
                "kind": {
                  "enum": [
                    "brand-identity",
                    "logo",
                    "wordmark",
                    "brand-mark"
                  ]
                },
                "source": {
                  "const": "code-generated"
                }
              },
              "required": [
                "kind",
                "source"
              ]
            },
            "then": false
          },
          {
            "if": {
              "properties": {
                "kind": {
                  "enum": [
                    "brand-identity",
                    "logo",
                    "wordmark",
                    "brand-mark"
                  ]
                },
                "source": {
                  "const": "image_gen"
                }
              },
              "required": [
                "kind",
                "source"
              ]
            },
            "then": {
              "properties": {
                "path": {
                  "not": {
                    "pattern": "\\.svg$"
                  }
                }
              }
            }
          }
        ],
        "required": [
          "id",
          "kind",
          "status",
          "required_by"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "brand-identity",
              "logo",
              "wordmark",
              "brand-mark",
              "hero-image",
              "product-card-image",
              "promo-image",
              "lifestyle-story-image",
              "footer-image",
              "app-device-image",
              "background-texture",
              "decorative-raster",
              "decorative-svg",
              "ui-icon",
              "concept-screenshot",
              "page-screenshot",
              "other"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "generated",
              "provided",
              "reused-existing",
              "rejected",
              "failed",
              "not-generated-with-reason",
              "missing"
            ]
          },
          "required_by": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "source": {
            "type": "string",
            "enum": [
              "image_gen",
              "user-provided",
              "existing-project",
              "code-generated",
              "not-applicable"
            ]
          },
          "format": {
            "type": "string",
            "enum": [
              "png",
              "jpg",
              "jpeg",
              "webp",
              "svg",
              "gif",
              "other"
            ]
          },
          "identity_asset": {
            "type": "boolean"
          },
          "inspection_status": {
            "type": "string",
            "enum": [
              "uninspected",
              "inspected",
              "accepted",
              "rejected",
              "not-applicable"
            ]
          },
          "worker_mode": {
            "type": "string",
            "enum": [
              "parallel-worker",
              "worker-batch",
              "main-workflow",
              "not-applicable"
            ]
          },
          "fallback_source": {
            "type": "string"
          },
          "consistency_group": {
            "type": "string"
          },
          "depends_on_asset_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "approved_reference_asset_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "visible_text": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "consistency_status": {
            "type": "string",
            "enum": [
              "unchecked",
              "consistent",
              "deviates",
              "accepted-exception",
              "not-applicable"
            ]
          },
          "section_role": {
            "type": "string"
          },
          "concept_reference_path": {
            "type": "string"
          },
          "crop_intent": {
            "type": "string"
          },
          "section_role_status": {
            "type": "string",
            "enum": [
              "unchecked",
              "matches",
              "minor-deviation",
              "deviates",
              "accepted-exception",
              "not-applicable"
            ]
          },
          "dimensions": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "width",
              "height"
            ],
            "properties": {
              "width": {
                "type": "integer",
                "minimum": 1
              },
              "height": {
                "type": "integer",
                "minimum": 1
              }
            }
          },
          "alt_text": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_referenced_assets_exist",
        "missing_assets"
      ],
      "properties": {
        "all_referenced_assets_exist": {
          "type": "boolean"
        },
        "missing_assets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "asset_consistency_path": {
          "type": "string"
        },
        "inconsistent_assets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "consistency_notes": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
