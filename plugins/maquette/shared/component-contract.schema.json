{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Ixe1/codex-plugins/master/plugins/maquette/shared/component-contract.schema.json",
  "title": "Maquette Component Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "batch",
    "selectors",
    "states",
    "accessibility",
    "responsive",
    "implementation_notes"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_name",
        "version",
        "status",
        "based_on_design_system_version"
      ],
      "properties": {
        "contract_name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "reviewed",
            "approved",
            "superseded"
          ]
        },
        "based_on_design_system_version": {
          "type": "string"
        },
        "source_direction_inventory_path": {
          "type": "string"
        },
        "source_visual_sheet_path": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "batch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slug",
        "category",
        "selector_allowlist",
        "critical_path"
      ],
      "properties": {
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "category": {
          "type": "string",
          "enum": [
            "core-primitives",
            "navigation-layout",
            "data-display",
            "cards-composites",
            "focused-follow-up",
            "other"
          ]
        },
        "selector_allowlist": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "critical_path": {
          "type": "boolean"
        }
      }
    },
    "selectors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "selector",
          "role",
          "rules"
        ],
        "properties": {
          "selector": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string"
          },
          "slots": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "rules": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/rule"
            }
          }
        }
      }
    },
    "states": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "selector",
          "state",
          "rules"
        ],
        "properties": {
          "selector": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "rules": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/rule"
            }
          }
        }
      }
    },
    "accessibility": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "responsive": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "implementation_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "property",
        "value"
      ],
      "properties": {
        "property": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string",
          "minLength": 1
        },
        "token_source": {
          "type": "string",
          "enum": [
            "design-system",
            "component",
            "page-local",
            "normalized"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
